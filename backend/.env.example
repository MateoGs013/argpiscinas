# Database
DATABASE_URL="mysql://user:password@localhost:3306/argpiscinas"

# JWT
JWT_SECRET="your_super_secret_key_here"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL="http://localhost:5173"
FRONTEND_URLS="http://localhost:5173,http://127.0.0.1:5173"

# Public site URL (sitemap/canonical defaults)
SITE_URL="https://argpiscinas.com"
SITEMAP_URL="https://argpiscinas.com/api/sitemap.xml"

# Rate limits
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10
CONTACT_RATE_WINDOW_MS=3600000
CONTACT_RATE_MAX=5

# Uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# Seed users (optional)
SEED_ADMIN_EMAIL="admin@argpiscinas.com"
SEED_ADMIN_PASSWORD="admin123"
SEED_EDITOR_EMAIL="editor@argpiscinas.com"
SEED_EDITOR_PASSWORD="editor123"
